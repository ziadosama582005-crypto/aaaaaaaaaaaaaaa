# ============================================
#  متغيرات البيئة - Loyalty Points System
#  أضف هذه المتغيرات في Render > Environment
# ============================================

# ──────────── 1. Firebase (مطلوب - أحدهما) ────────────
# الطريقة 1: في Render - حوّل ملف serviceAccountKey.json إلى Base64:
#   cat serviceAccountKey.json | base64 -w 0
# ثم ضع الناتج هنا:
FIREBASE_CONFIG_BASE64=your-base64-encoded-service-account-key

# الطريقة 2: محلياً - ضع مسار الملف:
# FIREBASE_CONFIG_PATH=serviceAccountKey.json

# ──────────── 2. مفتاح الأمان (مطلوب) ────────────
# أنشئ مفتاح عشوائي قوي بتنفيذ هذا الأمر:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# ──────────── 3. حساب المدير (مطلوب) ────────────
# غيّر هذه القيم لبيانات المدير الحقيقية
ADMIN_EMAIL=admin@loyalty.com
ADMIN_PASSWORD=your-strong-admin-password

# ──────────── 4. إعدادات الإيميل (مطلوب لإرسال أكواد التحقق) ────────────
# أنشئ App Password من حسابك Gmail:
# 1. فعّل التحقق بخطوتين: https://myaccount.google.com/signinoptions/two-step-verification
# 2. أنشئ App Password: https://myaccount.google.com/apppasswords
# 3. اختر اسم (مثلاً: Loyalty System) وانسخ الكلمة المكونة من 16 حرف
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ──────────── 5. اختياري ────────────
# APP_NAME=Loyalty Points System
# DEBUG=False
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
