# ============================================
#  متغيرات البيئة - Loyalty Points System
#  أضف هذه المتغيرات في Render > Environment
# ============================================

# ──────────── 1. قاعدة البيانات (مطلوب) ────────────
# في Render: أنشئ PostgreSQL Database من Dashboard
# ثم انسخ Internal Database URL وضعه هنا
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ──────────── 2. مفتاح الأمان (مطلوب) ────────────
# أنشئ مفتاح عشوائي قوي بتنفيذ هذا الأمر:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# ──────────── 3. حساب المدير (مطلوب) ────────────
# غيّر هذه القيم لبيانات المدير الحقيقية
ADMIN_EMAIL=admin@loyalty.com
ADMIN_PASSWORD=your-strong-admin-password

# ──────────── 4. اختياري ────────────
# APP_NAME=Loyalty Points System
# DEBUG=False
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
